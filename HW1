      },
      "source": [
        "## ให้ สร้าง list ของ เวลา ```['12:30:15','13:41:07',....]``` แล้ววนลูปเรียกฟังก์ชั่นคำนวณเวลาเป็น วินาที\n",
        "\n",
        "**commit ว่า HW3**"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "F5SleBYkkzKw",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "031f4ccf-102e-4a20-aea1-aaf27bc9f550"
      },
      "source": [
        "# ฟังก์ชันแปลงเวลาเป็นวินาที\n",
        "def time_to_seconds(time_str):\n",
        "    h, m, s = time_str.split(':')\n",
        "    total_seconds = int(h) * 3600 + int(m) * 60 + int(s)\n",
        "    return total_seconds\n",
        "\n",
        "# List ของเวลา\n",
        "times = [\n",
        "    '12:30:15',\n",
        "    '13:41:07',\n",
        "    '12:53:15',\n",
        "    '00:59:25',\n",
        "    '11:11:11',\n",
        "    '16:06:09'\n",
        "]\n",
        "\n",
        "print('ผลการคำนวณเวลาเป็นวินาที')\n",
        "print('-' * 40)\n",
        "\n",
        "# วนลูปเรียกฟังก์ชัน\n",
        "for t in times:\n",
        "    sec = time_to_seconds(t)\n",
        "    print(f'เวลา {t:>8} = {sec:>6,} วินาที')"
      ],
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "ผลการคำนวณเวลาเป็นวินาที\n",
            "----------------------------------------\n",
            "เวลา 12:30:15 = 45,015 วินาที\n",
            "เวลา 13:41:07 = 49,267 วินาที\n",
            "เวลา 12:53:15 = 46,395 วินาที\n",
